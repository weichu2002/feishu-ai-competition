    "service:stop": "node scripts/flowmate-service.js stop",
    "service:health": "node scripts/flowmate-service.js health",
    "service:panel": "node scripts/flowmate-control-panel.js",
    "service:install-autostart": "node scripts/flowmate-service.js install-autostart",
    "service:uninstall-autostart": "node scripts/flowmate-service.js uninstall-autostart",
    "self-test:core": "node scripts/self-test-flowmate-core.mjs",
    "self-test:regression": "node scripts/self-test-regression-matrix.mjs",
    "self-test:real-doc-source": "node scripts/self-test-real-document-source.mjs",
    "self-test:real-minutes-source": "node scripts/self-test-real-minutes-source.mjs",
    "self-test:team-knowledge-qa": "node scripts/self-test-team-knowledge-qa.mjs",
    "eval": "node eval/run-eval.js",
    "handover": "cat HANDOVER.md"
