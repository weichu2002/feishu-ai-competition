{
  "name": "flowmate",
  "version": "0.1.0",
  "description": "FlowMate: 会议驱动的个人承诺闭环 Agent",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "check:lark": "node scripts/check-lark.js",
    "setup:feishu": "node scripts/setup-feishu.js",
    "setup:task": "node scripts/setup-task.js",
    "mock:extract": "node scripts/mock-extract.js",
    "mock:ledger": "node scripts/mock-ledger.js",
    "mock:cards": "node scripts/mock-cards.js",
    "mock:premeeting": "node scripts/mock-premeeting.js",
    "mock:evening": "node scripts/mock-evening.js",
    "mock:full": "node scripts/mock-full.js",
    "demo:full": "node scripts/demo-full.js",
    "sync:skills": "node scripts/sync-skills.js",
    "scan:personal": "node scripts/assistant-entry.js scan-personal-messages",
    "start:personal": "node scripts/watch-personal-messages.js --interval 60",
    "watch:personal": "node scripts/watch-personal-messages.js --interval 60",
    "start:personal:once": "node scripts/watch-personal-messages.js --once --interval 60",
    "team:status": "node scripts/team-entry.js status",
    "team:ensure": "node scripts/team-entry.js ensure",
    "team:source-list": "node scripts/team-entry.js source-list",
    "team:source-add": "node scripts/team-entry.js source-add",
    "team:source-remove": "node scripts/team-entry.js source-remove",
    "team:source-enable": "node scripts/team-entry.js source-enable",
    "team:source-disable": "node scripts/team-entry.js source-disable",
    "team:member-add": "node scripts/team-entry.js member-add",
    "team:member-list": "node scripts/team-entry.js member-list",
    "team:member-remove": "node scripts/team-entry.js member-remove",
    "team:scan": "node scripts/team-entry.js scan-once",
    "team:warn": "node scripts/team-entry.js warn",
    "team:sync-status": "node scripts/team-entry.js sync-statuses",
    "team:dashboard": "node scripts/team-entry.js dashboard-refresh",
    "team:subscribe-events": "node scripts/team-entry.js subscribe-events",
    "team:digest": "node scripts/team-entry.js digest",
    "team:qa": "node scripts/team-entry.js qa",
    "team:unassigned": "node scripts/team-entry.js unassigned",
    "team:reassign": "node scripts/team-entry.js reassign",
    "watch:team": "node scripts/watch-team-sources.js --interval 300 --notify false --notify-owners true",
